# Stella Clover 환경변수 예시 — 복사 후 값 채우기:  cp .env.example .env
# (docker compose 가 자동으로 읽음. 절대 .env 를 커밋하지 말 것 — .gitignore 처리됨)

# ── PostgreSQL (compose 내부 db 서비스가 사용 / 앱은 DATABASE_URL 로 접속) ──
PGDATABASE=stella
PGUSER=stella
PGPASSWORD=change-me-strong-password
# 외부 Postgres를 쓸 경우엔 위 대신 앱에 DATABASE_URL 직접 지정하고 PGSSL=require:
# DATABASE_URL=postgres://user:pass@host:5432/db
# PGSSL=require

# ── OpenAI (Whisper + gpt-4o-mini 공용) ──
OPENAI_API_KEY=sk-...

# ── Google Drive ──
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# ── 크론 보호 / 워커 self-trigger 베이스 ──
CRON_SECRET=set-a-long-random-string
PUBLIC_BASE_URL=https://gpt.example.com

# ── 업로드 본문 한도(바이트, 기본 30MB). nginx-proxy-manager client_max_body_size 도 함께 상향 ──
MAX_BODY_BYTES=31457280
