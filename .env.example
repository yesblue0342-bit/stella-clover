# Stella Clover (OCI) 환경변수 — 실제 값은 절대 커밋 금지(.env 는 .gitignore).
PORT=8971

# ── Postgres (OCI 동거 컨테이너) ──
# 권장: DATABASE_URL 하나로 지정. 내부망(npm_default)이면 호스트=컨테이너명, 평문(sslmode 생략).
#   예) postgresql://stella:비밀번호@stella-postgres:5432/stella_clover
DATABASE_URL=
# (대안) DATABASE_URL 대신 개별 변수로도 가능(둘 중 하나만 채우면 됨):
#   DB_SERVER=stella-postgres   (컨테이너명/사설IP → 내부망 평문)
#   DB_NAME=stella_clover
#   DB_USER=stella
#   DB_PASSWORD=
#   DB_PORT=5432
# (선택) SSL: 기본 off(내부망 평문). 외부/TLS DB면 DB_SSL=true,
#        인증서 검증 강제는 DB_SSL_VERIFY=true (또는 URL에 ?sslmode=verify-full).

# ── OpenAI (Whisper STT + gpt-4o-mini 회의록 + gpt-4.1-mini 화자/요약) ──
OPENAI_API_KEY=

# ── Google Drive (음원 청크 + 회의록 저장) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── 백그라운드 전사 잡 동시 실행 상한(기본 2) ──
JOBS_CONCURRENCY=2

# ── (선택) /api/cleanup 외부 호출 보호용 ──
CRON_SECRET=
