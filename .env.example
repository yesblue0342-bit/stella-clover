# Stella Clover (OCI) 환경변수 — 실제 값은 절대 커밋 금지(.env 는 .gitignore).
PORT=8970

# ── SQL Server ──
# OCI 동거 MSSQL 컨테이너 권장: DB_SERVER=stella-mssql (점없는 컨테이너명 → 자체서명 TLS 자동 허용).
# Azure SQL(*.database.windows.net)도 그대로 호환(암호화/인증서검증 유지).
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
# (호환) 기존 Azure 변수도 인식됨: CL_DB_SV / CL_DB_NM / CL_DB_USR / CL_DB_PW
# (선택) TLS 강제 오버라이드: DB_ENCRYPT=true|false, DB_TRUST_SERVER_CERT=true|false

# ── OpenAI (Whisper STT + gpt-4o-mini 회의록 + gpt-4.1-mini 화자/요약) ──
OPENAI_API_KEY=

# ── Google Drive (음원 청크 + 회의록 저장) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── 백그라운드 전사 잡 동시 실행 상한(기본 2) ──
JOBS_CONCURRENCY=2

# ── (선택) /api/cleanup 외부 호출 보호용 ──
CRON_SECRET=
