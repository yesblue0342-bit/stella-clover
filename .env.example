# Stella Clover (OCI) 환경변수 — 실제 값은 절대 커밋 금지(.env 는 .gitignore).
PORT=8971

# ── Postgres (OCI 동거 컨테이너) ──
# 권장: DATABASE_URL 하나로 지정. 내부망(npm_default)이면 호스트=컨테이너명, 평문(sslmode 생략).
#   예) postgresql://stella:비밀번호@stella-postgres:5432/stella_clover
DATABASE_URL=
# (대안) DATABASE_URL 대신 개별 변수로도 가능(둘 중 하나만 채우면 됨):
#   DB_SERVER=stella-postgres   (컨테이너명/사설IP → 내부망 평문)
#   DB_NAME=stella_clover
#   DB_USER=stella
#   DB_PASSWORD=
#   DB_PORT=5432
# (선택) SSL: 기본 off(내부망 평문). 외부/TLS DB면 DB_SSL=true,
#        인증서 검증 강제는 DB_SSL_VERIFY=true (또는 URL에 ?sslmode=verify-full).

# ── OpenAI (gpt-4o-transcribe/whisper-1 STT + gpt-4.1-mini 교정·화자·요약 + gpt-4o-mini 회의록) ──
OPENAI_API_KEY=

# ── CBO Spec & Code Review (개인용 접근 게이트 + AI/GitHub 연결) ──
# 화면 접근용 개인 비밀번호. 충분히 긴 임의 문자열로 설정.
CBO_ACCESS_PW=
# Claude API Console / Google AI Studio에서 발급한 API 키
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# fine-grained PAT: yesblue0342-bit/0Program Contents read/write 권한
GITHUB_TOKEN=
CBO_GITHUB_OWNER=yesblue0342-bit
CBO_GITHUB_REPO=0Program
CBO_GITHUB_BRANCH=main
# OCI: /app/data/0Program(기존 persistent volume), Windows 로컬 실행: C:/codex/0Program
CBO_REPO_PATH=/app/data/0Program
# 자동 commit 작성자(선택)
# CBO_GIT_USER_NAME=Stella Clover CBO Review
# CBO_GIT_USER_EMAIL=cbo-review@localhost
# 연결 화면에서 저장한 키의 로컬 보관 위치(기본 data/cbo-review)
# CBO_DATA_DIR=/app/data/cbo-review

# ── Google Drive (원본 오디오 보관 + 회의록 텍스트 백업 + Flow 결과 저장) ──
#   ※ STT 는 로컬 임시 파일로 수행(Drive 인증 장애와 무관하게 전사 동작 — invalid_client 회귀 방지).
#     전사·회의록 저장이 끝난 뒤 원본 오디오를 아래 보관 폴더로 업로드하고 로컬에서 삭제한다.
#     보관 업로드 실패 시 잡은 실패로 표시되지만 회의록/이력은 이미 저장되어 있고, 파일은 보존된다('다시 시도' 가능).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# (선택) 원본 오디오 보관 폴더 ID — 기본값은 코드에 지정된 stella 보관 폴더(1ap3oDMkYlTnK5YXI2yR0-ZiHlrgp-1r8)
# DRIVE_AUDIO_FOLDER_ID=
# (선택) 노트 저장 폴더 ID — Stella GPT와 동일 폴더 공유(기본값 1Gd_4isQFTIQi0DjaDfE85IZM-tG1cClZ, 폴더ID는 비밀 아님)
# STELLA_NOTES_FOLDER_ID=

# ── 백그라운드 전사 잡 동시 실행 상한(기본 2) ──
JOBS_CONCURRENCY=2

# ── (선택) 오디오 임시 저장 경로 (기본 /app/data/chunks, 도커 볼륨 ${NAME}-data 에 매핑) ──
#   업로드 파트/조립 원본/전처리 청크가 여기 저장되고, 잡 완료(원본 Drive 보관 성공) 시 삭제된다.
# CHUNK_DIR=/app/data/chunks

# ── (선택) ffmpeg 실행 상한(ms, 기본 30분) — 손상 파일 좀비 방지 ──
# FFMPEG_TIMEOUT_MS=1800000

# ── (선택) /api/cleanup 외부 호출 보호용 ──
CRON_SECRET=
